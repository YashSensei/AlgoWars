# Keep the Docker build context small and fast.
# Anything not needed to build/run the backend goes here.

node_modules
dist
.git
.github
.husky
.vscode
.idea
.playwright-mcp
.claude

# Environment files — never ship secrets into an image.
# In prod, env vars come from Render's dashboard.
.env
.env.*
!.env.example

# Frontend is deployed separately on Vercel — exclude from backend image.
frontend

# Misc dev / docs
README.md
PLAN.md
CLAUDE.md
*.log
.DS_Store
codeforces_scraped_problems
